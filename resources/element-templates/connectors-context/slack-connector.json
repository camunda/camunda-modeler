{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Slack Connector",
  "id": "io.camunda.hub.connectors.SlackOutbound.v1",
  "description": "Post a message to Slack (Hub prototype)",
  "version": 1,
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "properties": [
    {
      "type": "Hidden",
      "value": "io.camunda:slack:1",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "label": "Channel",
      "type": "String",
      "binding": {
        "type": "zeebe:input",
        "name": "channel"
      }
    },
    {
      "label": "Message",
      "type": "String",
      "binding": {
        "type": "zeebe:input",
        "name": "text"
      }
    }
  ],
  "keywords": [
    "post message",
    "send message",
    "slack message",
    "channel message",
    "notify slack",
    "slack notification",
    "team notification",
    "chat message",
    "messaging",
    "list messages",
    "conversations",
    "post to channel",
    "send to channel",
    "slack alert",
    "slack update"
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}